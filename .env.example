# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com
NEXT_PUBLIC_CONTACT_EMAIL=hola@tu-empresa.com

# ─── Email de solicitudes de demo (Resend) ────────────────────────────────────
# 1. Crea una cuenta en https://resend.com (gratis hasta 3,000 emails/mes)
# 2. Genera una API key y pégala aquí
# 3. Configura tu dominio de envío en el dashboard de Resend
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Tu Empresa <noreply@tu-dominio.com>
EMAIL_TO=ventas@tu-empresa.com

# ─── Analytics (opcional) ─────────────────────────────────────────────────────
# Google Analytics 4 — deja vacío para desactivar
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-YOUR_GA_ID
